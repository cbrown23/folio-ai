# Auth.js — required
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=

# LinkedIn OAuth — from https://linkedin.com/developers
# Enable "Sign In with LinkedIn using OpenID Connect" on your app
# Redirect URI to register: https://<your-domain>/api/auth/callback/linkedin
#                           http://localhost:3000/api/auth/callback/linkedin
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Anthropic — for the ReAct agent
ANTHROPIC_API_KEY=

# Voyage AI — for embeddings (RAG)
# Get your key at https://dash.voyageai.com
VOYAGE_API_KEY=

# Neon — for pgvector / RAG
DATABASE_URL=

# Owner identity
# OWNER_ID: scopes all vector DB content to your portfolio.
#   Set to your LinkedIn sub (visible in session after first sign-in). Defaults to 'default'.
# OWNER_EMAIL: gates access to the content studio. Must match your LinkedIn email.
OWNER_ID=
OWNER_EMAIL=

# Owner profile — used in the UI, agent prompts, and page metadata
OWNER_NAME=
OWNER_TITLE=
OWNER_LOCATION=
OWNER_LINKEDIN=
OWNER_GITHUB=
OWNER_DOMAIN=

# Site metadata
SITE_TITLE=folio-ai
SITE_DESCRIPTION=AI-native portfolio — architecture case studies and an embedded AI assistant.
SITE_URL=

# Agent persona
AGENT_NAME=Portfolio Assistant
AGENT_GREETING=Hi — I can answer questions about this portfolio, or help you schedule time.
# Your folio slug (used to build the capabilities page URL in the greeting)
FOLIO_SLUG=

# Cal.com — for scheduling integration
CAL_API_KEY=
CAL_USERNAME=
CAL_DEFAULT_EVENT=30min
